{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) astro dev",
    "build": "cross-env PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) astro build",
    "start": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check",
    "format": "prettier --write \"**/*.{astro,js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{astro,js,jsx,ts,tsx,json,css,md}\"",
    "vercel-build": "cross-env PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) astro build"
  },
  "dependencies": {
    "@iconify-json/simple-icons": "^1.2.80",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "astro-eslint-parser": "^1.3.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "postcss": "^8.5.4",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
